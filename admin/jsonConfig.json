{
	"i18n": true,
	"type": "tabs",
	"items": {
		"_connectionTab": {
			"type": "panel",
			"label": "connectionTab",
			"items": {
				"protocol": {
					"type": "select",
					"label": "protocol",
					"sm": 3,
					"options": [
						{ "label": "HTTP", "value": "http" },
						{ "label": "HTTPS", "value": "https" }
					],
					"newLine": true
				},
				"host": {
					"type": "text",
					"label": "host",
					"sm": 6,
					"placeholder": "192.168.1.100",
					"validator": "data.host && data.host.length > 0",
					"validatorErrorText": "hostRequired",
					"validatorNoSaveOnError": true
				},
				"port": {
					"type": "number",
					"label": "port",
					"sm": 3,
					"min": 1,
					"max": 65535
				},
				"organization": {
					"type": "text",
					"label": "organization",
					"sm": 6,
					"newLine": true
				},
				"token": {
					"type": "password",
					"label": "apiToken",
					"sm": 6,
					"visible": true
				},
				"testConnection": {
					"type": "sendto",
					"label": "testConnection",
					"sm": 4,
					"newLine": true,
					"command": "testConnection",
					"variant": "contained",
					"jsonData": "{\"protocol\": \"${data.protocol}\", \"host\": \"${data.host}\", \"port\": ${data.port}, \"organization\": \"${data.organization}\", \"token\": \"${data.token}\"}",
					"alsoDependsOn": ["protocol", "host", "port", "organization", "token"]
				}
			}
		},
		"_groupsTab": {
			"type": "panel",
			"label": "loggingGroupsTab",
			"items": {
				"_groupsInfo": {
					"type": "staticText",
					"label": "groupsInfo",
					"sm": 12
				},
				"groups": {
					"type": "table",
					"label": "loggingGroups",
					"sm": 12,
					"uniqueColumns": ["name"],
					"items": [
						{
							"attr": "enabled",
							"type": "checkbox",
							"title": "enabled",
							"width": "8%",
							"default": true
						},
						{
							"attr": "name",
							"type": "text",
							"title": "groupName",
							"width": "22%",
							"filter": true,
							"sort": true
						},
						{
							"attr": "bucket",
							"type": "text",
							"title": "bucket",
							"width": "20%"
						},
						{
							"attr": "triggerType",
							"type": "select",
							"title": "triggerType",
							"width": "18%",
							"options": [
								{ "label": "triggerCron", "value": "cron" },
								{ "label": "triggerOnChange", "value": "onChange" }
							],
							"default": "cron"
						},
						{
							"attr": "cronExpression",
							"type": "text",
							"title": "cronExpression",
							"width": "22%",
							"default": "*/15 * * * *",
							"help": "cronHelp"
						},
						{
							"attr": "batchWrite",
							"type": "checkbox",
							"title": "batchWrite",
							"width": "10%",
							"default": true
						}
					],
					"default": []
				}
			}
		},
		"_datapointsTab": {
			"type": "panel",
			"label": "datapointsTab",
			"items": {
				"_datapointsInfo": {
					"type": "staticText",
					"label": "datapointsInfo",
					"sm": 12
				},
				"datapoints": {
					"type": "table",
					"label": "datapoints",
					"sm": 12,
					"items": [
						{
							"attr": "enabled",
							"type": "checkbox",
							"title": "enabled",
							"width": "6%",
							"default": true
						},
						{
							"attr": "group",
							"type": "autocompleteSendTo",
							"command": "getGroupNames",
							"freeSolo": true,
							"alsoDependsOn": ["groups"],
							"title": "group",
							"width": "14%",
							"filter": true,
							"sort": true
						},
						{
							"attr": "objectId",
							"type": "objectId",
							"title": "objectId",
							"width": "20%",
							"filter": {
								"type": "state"
							}
						},
						{
							"attr": "measurement",
							"type": "text",
							"title": "measurement",
							"width": "20%"
						},
						{
							"attr": "field",
							"type": "text",
							"title": "fieldName",
							"width": "14%",
							"default": "value"
						},
						{
							"attr": "tags",
							"type": "text",
							"title": "tags",
							"width": "26%",
							"help": "tagsHelp"
						}
					],
					"default": []
				}
			}
		},
		"_advancedTab": {
			"type": "panel",
			"label": "advancedTab",
			"items": {
				"writeTimeout": {
					"type": "number",
					"label": "writeTimeout",
					"sm": 4,
					"min": 1000,
					"max": 60000,
					"help": "writeTimeoutHelp"
				},
				"retryOnError": {
					"type": "checkbox",
					"label": "retryOnError",
					"sm": 4,
					"newLine": true
				},
				"maxRetries": {
					"type": "number",
					"label": "maxRetries",
					"sm": 4,
					"min": 0,
					"max": 10,
					"hidden": "!data.retryOnError"
				},
				"enableDebugLogs": {
					"type": "checkbox",
					"label": "enableDebugLogs",
					"sm": 4,
					"newLine": true
				}
			}
		}
	}
}
