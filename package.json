{
  "name": "iobroker.influxdb-prologger",
  "version": "1.0.0",
  "description": "Flexible InfluxDB v2 data logger with configurable logging groups, multiple buckets, cron-based and on-change triggers",
  "author": {
    "name": "Simon Prosen",
    "email": "simon@prosen.dev"
  },
  "contributors": [
    {
      "name": "Simon Prosen"
    }
  ],
  "homepage": "https://github.com/simpros/ioBroker.influxdb-prologger",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "influxdb",
    "logging",
    "data-logger",
    "iot",
    "smart-home",
    "monitoring",
    "time-series"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/simpros/ioBroker.influxdb-prologger.git"
  },
  "engines": {
    "node": ">= 20"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "@iobroker/adapter-react-v5": "^8.1.6",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "cron": "^4.4.0",
    "react": "^19.2.4",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@iobroker/build-tools": "^3.0.1",
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/dev-server": "^0.8.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/iobroker": "npm:@iobroker/types@^7.1.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "vite": "^6.4.1"
  },
  "main": "build/main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*|.eslintrc).{json,json5}",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "build/",
    "www/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "build:gui": "node tasks",
    "watch": "build-adapter ts --watch",
    "prebuild:ts": "rimraf build",
    "build:ts": "build-adapter ts",
    "watch:ts": "build-adapter ts --watch",
    "test:ts": "mocha --config test/mocharc.custom.json",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:ts && npm run test:package",
    "check": "tsc --noEmit",
    "lint": "eslint -c eslint.config.mjs .",
    "translate": "translate-adapter",
    "release": "release-script",
    "dev-server": "dev-server"
  },
  "bugs": {
    "url": "https://github.com/simpros/ioBroker.influxdb-prologger/issues"
  },
  "readmeFilename": "README.md"
}
